programa {
  funcao inicio() {
    //programaSemáfaro
real velocidade // declarando variavel

    //Entrada de dados
    escreva("Qual é a velocidade atual do carro? ")
    leia(velocidade)

    //Estrutura Concicional
    se(velocidade >80){
    escreva("MULTADO! voce excedeu o limite de velocidae: 80 km/h")

  }senao{
    escreva("velocidade permitida. Dirija com cuidado!")
  }
escreva("n")// quebra uma linha
}
}